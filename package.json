{
  "name": "@sablier/sandbox",
  "description": "End-to-end EVM integration examples for Sablier Lockup v4.0",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "author": {
    "name": "Sablier Labs Ltd",
    "url": "https://sablier.com"
  },
  "bugs": {
    "url": "https://github.com/sablier-labs/sandbox/issues"
  },
  "homepage": "https://github.com/sablier-labs/sandbox#readme",
  "license": "LGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sablier-labs/sandbox.git"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,json,jsonc,css}": [
      "biome check --write"
    ],
    "*.{ts,tsx}": [
      "biome lint --write --only correctness/noUnusedImports",
      "eslint --fix --cache"
    ],
    "*.{md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@antfu/ni": "^25",
    "@biomejs/biome": "^2.4",
    "@sablier/devkit": "^1.16",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.57",
    "@typescript/native-preview": "7.0.0-dev.20260429.1",
    "babel-plugin-react-compiler": "^1",
    "eslint": "^10",
    "eslint-plugin-better-tailwindcss": "^4.3",
    "eslint-plugin-react-hooks": "^7",
    "husky": "^9",
    "lint-staged": "^16",
    "prettier": "^3.8",
    "typescript": "^5.9"
  }
}
